{
	"name": "site",
	"description": "@superti4r portfolio site using Svelte 5",
	"author": {
		"name": "Bachtiar Dwi Pramudi",
		"github": "superti4r",
		"instagram": "superti4r"
	},
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/auth.ts --output src/lib/database/schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@neoconfetti/svelte": "^2.2.2",
		"@neondatabase/serverless": "^1.0.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"better-auth": "^1.4.21",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shiki": "^4.0.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1"
	},
	"overrides": {
		"better-auth": "1.4.21",
		"@better-auth/core": "1.4.21"
	},
	"dependencies": {
		"@giscus/svelte": "^3.1.0",
		"@iconify/svelte": "^5.2.1",
		"@paralleldrive/cuid2": "^3.3.0",
		"bits-ui": "^2.16.2",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"gsap": "^3.14.2",
		"svelte-french-toast": "^1.2.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	}
}
